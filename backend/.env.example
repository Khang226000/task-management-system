PORT=443
PORT_HTTP=80
NODE_ENV=production
DNS_PORT=5454

# SQL Server — Cấu hình kết nối database
# DB_HOST: Tên server SQL Server (ví dụ: SERVERNAME\INSTANCENAME hoặc IP)
DB_HOST=YOUR_SERVER_NAME\INSTANCE
DB_PORT=1433
DB_NAME=QLCV_DB
DB_USER=sa
DB_PASSWORD=YOUR_STRONG_PASSWORD

# JWT — Bắt buộc đổi secret này trong production (tối thiểu 32 ký tự ngẫu nhiên)
JWT_SECRET=your_very_long_random_secret_here_min_32_chars
JWT_EXPIRES_IN=30d

# Frontend URL (dùng cho CORS — đặt đúng domain production)
FRONTEND_URL=https://casictask.local
