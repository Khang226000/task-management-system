NODE_ENV=production
PORT=5000

# PostgreSQL Connection URL
# Local:  postgresql://USER:PASSWORD@localhost:5432/DATABASE
# Render: postgresql://USER:PASSWORD@HOST/DATABASE  (Render tự cung cấp)
DATABASE_URL=postgresql://postgres:@db.vwpikekmgnhyvpzrussl.supabase.co:5432/postgres

# SSL cho PostgreSQL
# - Render/Supabase/Railway: để trống (mặc định bật SSL)
# - Local không có SSL: DB_SSL=false
# DB_SSL=false

# JWT Secret — tối thiểu 32 ký tự ngẫu nhiên
# Tạo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here_min_32_chars
JWT_EXPIRES_IN=30d

# Frontend URL cho CORS
# Local: http://localhost:5173
# Production: https://your-app.onrender.com
FRONTEND_URL=https://your-app.onrender.com
